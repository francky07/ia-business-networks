#!/usr/bin/env python3
import sys, os, sqlite3, subprocess, time
DB_PATH = os.path.expanduser("~/ia_shared/db/nexus.db")

def get_unsold_count():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM emails WHERE vendu=0")
    count = c.fetchone()[0]
    conn.close()
    return count

while True:
    # Décision dynamique
    seuil, state, action = decide_seuil()
    nb = get_unsold_count()
    if nb >= seuil:
    nb = get_unsold_count()
    if nb > 0:
        print(f"🧠 Vente déclenchée pour {nb} emails")
        subprocess.run(["python", os.path.expanduser("~/departement_ventes/sell_emails_paypal.py")])
        reward = nb * 0.01  # récompense basée sur le nombre vendu
        record_reward(reward)
    else:
        print(f"📭 Aucun email en stock")
    time.sleep(60)
