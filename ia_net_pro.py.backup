def load_memory():
    if os.path.exists(MEM_FILE):
        with mem_lock:
            with open(MEM_FILE) as f:
                return json.load(f)
    return {"stats":{"cycle":0,"actions":0},"errors":[], "last_balance":0.0}
def save_memory(d):
    with mem_lock:
        with open(MEM_FILE, "w") as f:
            json.dump(d, f, indent=2)

def send_telegram(message):
    global TELEGRAM_CHAT_ID
