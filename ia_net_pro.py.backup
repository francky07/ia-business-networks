class EconomicAgent(threading.Thread):
    def __init__(self, name, interval=60):
        super().__init__(daemon=True); self.name=name; self.interval=interval; self.last_run=0
    def run(self):
        while True:
            now=time.time()
            if now-self.last_run>=self.interval:
                self.last_run=now
                try: self.execute()
                except: pass
            time.sleep(30)
    def execute(self): pass
    def log(self,msg): print(f"[💰 {self.name}] {msg}")

class WalletMonitor(EconomicAgent):
    def execute(self):
        try:
            bal = float(w3.from_wei(w3.eth.get_balance(WALLET),'ether'))
            mem = load_memory()
            last = mem.get("last_balance",0.0)
            if bal > last + 0.0001:
                self.log(f"🎉 Don reçu ! +{bal-last:.6f} BNB")
                send_telegram(f"🎉 Don reçu ! +{bal-last:.6f} BNB")
            mem["last_balance"]=bal
            save_memory(mem)
        except: pass
class CostOptimizer(EconomicAgent):
    def execute(self):
        try:
            gas = w3.from_wei(w3.eth.gas_price, 'gwei')
            mem = load_memory(); mem["gas_price"]=float(gas); save_memory(mem)
            self.log(f"Gaz: {gas:.2f} Gwei")
        except: pass
