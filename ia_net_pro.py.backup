        bal = load_memory().get("last_balance",0)
        if bal >= 0.01: self.log(f"💹 Solde suffisant ({bal:.4f} BNB) – staking recommandé")
class ROIAgent(EconomicAgent):
    def execute(self):
        mem = load_memory()
        roi = sum(d["amount"] for d in mem.get("donations",[])) - mem.get("total_costs",0.0)
        self.log(f"ROI: {roi:.6f} BNB")
        mem["roi"]=roi; save_memory(mem)

for agent in [WalletMonitor("WalletMonitor",120), CostOptimizer("CostOptimizer",300), MonetizationAgent("Monetization",600), InvestmentAgent("Investment",900), ROIAgent("ROI",1800)]:
